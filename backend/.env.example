# Environment Configurations
ENV=development
PORT=8000
HOST=0.0.0.0

# LLM API Keys (Configure at least one)
# Obtain a free, lightning-fast API key at https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here
# Or obtain an OpenAI API key at https://platform.openai.com/
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# LLM Selection
# Choices: groq | openai
LLM_PROVIDER=groq
# For groq, choices: llama3-8b-8192 or llama3-70b-8192
# For openai, choices: gpt-3.5-turbo or gpt-4-turbo
LLM_MODEL=llama3-8b-8192

# Transcription Settings
# Choices: local (runs whisper locally in python) | api (dispatches to groq/openai endpoints)
WHISPER_MODE=local
# Local whisper model size. Choices: tiny | base | small | medium
# 'tiny' is ultra fast on CPU, 'base' has slightly better accuracy.
WHISPER_LOCAL_MODEL=base
# API provider if WHISPER_MODE=api. Choices: openai | groq
WHISPER_API_PROVIDER=openai

# Disk Storage Directories
DOWNLOADS_DIR=./downloads
INDEXES_DIR=./indexes
DATA_DIR=./data

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:5173
